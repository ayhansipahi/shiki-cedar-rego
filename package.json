  "description": "Cedar and Rego TextMate grammars for Shiki syntax highlighting",
  "license": "MIT",
  "author": "Software Project Hub",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayhansipahi/shiki-cedar-rego.git"
  },
  "keywords": [
    "shiki",
    "cedar",
    "rego",
    "opa",
    "aws-verified-permissions",
